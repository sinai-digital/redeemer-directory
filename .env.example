# Supabase project credentials — get these from your Supabase dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Keep-alive cron secret (used by /api/keep-alive)
CRON_SECRET=your-cron-secret-here

# Resend email (for invite emails)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Redeemer Church Directory <noreply@directory.redeemerriverview.org>
